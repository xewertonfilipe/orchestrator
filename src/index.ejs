<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Root Config</title>
  <meta http-equiv="Content-Security-Policy"
    content="default-src 'self' https: localhost:*; script-src 'unsafe-inline' 'unsafe-eval' 'self' https: localhost:*; connect-src 'self' https: localhost:* ws://localhost:*; style-src 'unsafe-inline' 'self' https:; object-src 'none'; base-uri 'self'; frame-ancestors 'self';">
  <meta name="importmap-type" use-injector />
  <!-- If you wish to turn off import-map-overrides for specific environments (prod), uncomment the line below -->
  <!-- More info at https://github.com/single-spa/import-map-overrides/blob/main/docs/configuration.md#domain-list -->
  <!-- <meta name="import-map-overrides-domains" content="denylist:prod.example.com" /> -->

  <!-- Shared dependencies go into this import map -->
  <script type="injector-importmap">
    {
      "imports": {
        "single-spa": "https://cdn.jsdelivr.net/npm/single-spa@5.9.3/lib/es2015/single-spa.min.js",
        "react": "https://esm.sh/react@19.0.0",
        "react-dom": "https://esm.sh/react-dom@19.0.0?external=react",
        "react-dom/client": "https://esm.sh/react-dom@19.0.0/client?external=react",
        "react/jsx-runtime": "https://esm.sh/react@19.0.0/jsx-runtime?external=react",
        "react/jsx-dev-runtime": "https://esm.sh/react@19.0.0/jsx-dev-runtime?external=react"
      }
    }
  </script>
  <link rel="preload" href="https://cdn.jsdelivr.net/npm/single-spa@5.9.3/lib/es2015/single-spa.min.js" as="module">

  <% if (isContainerLocal) { %>
    <script type="injector-importmap">
      {
        "imports": {
          "@bytebank/account": "http://localhost:8083/bytebank-account.js",
          "@bytebank/authentication": "http://localhost:8087/bytebank-authentication.js",
          "@bytebank/menu": "http://localhost:8082/bytebank-menu.js",
          "@bytebank/navbar": "http://localhost:8081/bytebank-navbar.js",
          "@bytebank/root-config": "//localhost:8080/bytebank-root-config.js",
          "@bytebank/statement": "http://localhost:8084/bytebank-statement.js",
          "@bytebank/transaction": "http://localhost:8085/bytebank-transaction.js"
        }
      }
    </script>
  <% } else if (isLocal) { %>
    <script type="injector-importmap">
      {
        "imports": {
          "@bytebank/account": "http://localhost:9004/bytebank-account.js",
          "@bytebank/authentication": "http://localhost:9007/bytebank-authentication.js",
          "@bytebank/dashboard": "http://localhost:9002/bytebank-dashboard.js",
          "@bytebank/menu": "http://localhost:9003/bytebank-menu.js",
          "@bytebank/navbar": "http://localhost:9001/bytebank-navbar.js",
          "@bytebank/not-found": "http://localhost:8502/bytebank-not-found.js",
          "@bytebank/root-config": "//localhost:9000/bytebank-root-config.js",
          "@bytebank/statement": "http://localhost:9005/bytebank-statement.js",
          "@bytebank/transaction": "http://localhost:9006/bytebank-transaction.js",
          "@bytebank/util": "http://localhost:8505/bytebank-util.js"
        }
      }
    </script>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/import-map-overrides@5.1.1/dist/import-map-overrides.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@single-spa/import-map-injector@2.0.1/lib/import-map-injector.js"></script>
</head>

<body>
  <noscript>
    You need to enable JavaScript to run this app.
  </noscript>
  <main></main>
  <script>
    if (window.importMapInjector && window.importMapInjector.initPromise) {
      window.importMapInjector.initPromise.then(() => {
        import('@bytebank/root-config');
      });
    }
  </script>
  <import-map-overrides-full show-when-local-storage="devtools" dev-libs></import-map-overrides-full>
</body>

</html>